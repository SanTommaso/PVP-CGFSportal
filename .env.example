VITE_DATA_SOURCE=prisma
DATABASE_URL="file:./prod.db"

# Segreto per firmare i JWT — genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_questo_con_una_stringa_casuale_lunga

# Porta su cui ascolta il server Express (default: 3000)
PORT=3000

# Imposta sempre "production" sul server
NODE_ENV=production
